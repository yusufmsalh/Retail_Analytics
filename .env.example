# ══════════════════════════════════════════════════════════════════
# .env.example — copy this to .env and fill in real values
# NEVER commit .env to version control
# ══════════════════════════════════════════════════════════════════

# ── SQL Server ────────────────────────────────────────────────────
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=RetailDB
DB_USER=sa
DB_PASSWORD=your_strong_password_here

# ── .NET API ──────────────────────────────────────────────────────
API_BASE_URL=http://localhost:5000/api
API_JWT_TOKEN=your_jwt_bearer_token_here

# ── Slack Incoming Webhook ────────────────────────────────────────
# Leave blank or as-is to run in simulation mode (logs only)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Alert & Detection Thresholds ─────────────────────────────────
LOW_STOCK_THRESHOLD=10        # alert if stock < this value
ANOMALY_Z_THRESHOLD=3.0       # standard deviations for outlier detection
ANOMALY_LOOKBACK_DAYS=90      # how many days of history to scan

# ── Output ────────────────────────────────────────────────────────
OUTPUT_DIR=./output           # all reports and logs go here

# ── Email (optional — simulation mode used if SMTP_HOST is blank) ─
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REPORT_SENDER_EMAIL=analytics@store.com
REPORT_RECIPIENT_EMAIL=manager@store.com
